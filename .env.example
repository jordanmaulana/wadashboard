# --- Django ---
SECRET_KEY=
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# --- Database ---
# Leave POSTGRES_HOST empty for SQLite (host dev). Compose: POSTGRES_HOST=postgres.
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=5432

# --- Google OAuth ---
GOOGLE_OAUTH_CLIENT_ID=

# --- Mayar (payments) ---
MAYAR_API_KEY=
MAYAR_WEBHOOK_TOKEN=
MAYAR_BASE_URL=https://api.mayar.id/hl/v1
PAYMENT_REDIRECT_URL=http://localhost:5173/

# --- WhatsApp ---
# Shared secret the relay sends as the X-Callback-Token header. Leave empty to reject all ingest calls.
WHATSAPP_WEBHOOK_TOKEN=

# --- URLs ---
SITE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# --- Frontend build args ---
VITE_API_URL=http://localhost:8000
VITE_GOOGLE_CLIENT_ID=
